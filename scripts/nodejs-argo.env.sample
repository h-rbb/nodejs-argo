# nodejs-argo 配置文件示例 (Sample Configuration File)
# 用于iStoreOS/OpenWRT系统
# 将此文件复制到 /etc/nodejs-argo.env 并根据需要修改

# =============================================================================
# 基础配置 (Basic Configuration)
# =============================================================================

# HTTP服务端口 (HTTP Service Port)
# 订阅地址将通过此端口访问: http://路由器IP:PORT/sub
PORT=3000

# Argo隧道端口 (Argo Tunnel Port)
# 用于xray监听的端口
ARGO_PORT=8001

# 用户UUID (User UUID)
# 重要：请修改为您自己的UUID，不要使用默认值
# 可以通过在线工具生成: https://www.uuidgenerator.net/
# 或在路由器上运行: cat /proc/sys/kernel/random/uuid
UUID=CHANGE-ME-TO-YOUR-OWN-UUID

# =============================================================================
# Argo隧道配置 (Argo Tunnel Configuration)
# =============================================================================

# 固定隧道域名 (Fixed Tunnel Domain)
# 留空则使用临时隧道（推荐新手使用）
# 示例: example.yourdomain.com
ARGO_DOMAIN=

# 固定隧道密钥 (Fixed Tunnel Token/JSON)
# 支持两种格式:
# 1. Token格式 (推荐): 120-250个字符的token
# 2. JSON格式: 包含TunnelSecret的完整JSON配置
# 留空则使用临时隧道
ARGO_AUTH=

# =============================================================================
# 哪吒探针配置 (Nezha Monitoring Configuration)
# =============================================================================

# 哪吒服务器地址 (Nezha Server)
# 哪吒v1格式: nz.example.com:8008
# 哪吒v0格式: nz.example.com
NEZHA_SERVER=

# 哪吒端口 (Nezha Port)
# 使用哪吒v1时留空
# 使用哪吒v0时需填写
NEZHA_PORT=

# 哪吒密钥 (Nezha Key)
# 哪吒v1的NZ_CLIENT_SECRET或哪吒v0的agent密钥
NEZHA_KEY=

# =============================================================================
# 节点优选配置 (Node Optimization Configuration)
# =============================================================================

# 优选域名或IP (Preferred Domain/IP)
# 用于客户端连接的Cloudflare优选IP或域名
CFIP=cdns.doon.eu.org

# 优选端口 (Preferred Port)
# 对应优选IP/域名的端口
CFPORT=443

# 节点名称前缀 (Node Name Prefix)
# 留空则使用ISP信息作为节点名
# 示例: AX1800Pro, MyRouter, HomeServer
NAME=

# =============================================================================
# 订阅上传配置 (Subscription Upload Configuration)
# =============================================================================

# 订阅上传地址 (Subscription Upload URL)
# 如果您部署了Merge-sub项目，填写其首页地址
# 示例: https://merge.example.com
UPLOAD_URL=

# 项目URL (Project URL)
# 用于生成订阅地址和保活访问
# 示例: https://your-router.example.com
PROJECT_URL=

# 自动保活 (Auto Keep-alive)
# 是否开启自动访问保活功能
# false: 关闭
# true: 开启（需同时填写PROJECT_URL）
AUTO_ACCESS=false

# =============================================================================
# 文件路径配置 (File Path Configuration)
# =============================================================================

# 运行目录 (Runtime Directory)
# 用于存储临时文件和日志
FILE_PATH=/opt/nodejs-argo/tmp

# 订阅路径 (Subscription Path)
# 访问订阅的URL路径
# 完整地址: http://路由器IP:PORT/SUB_PATH
SUB_PATH=sub

# =============================================================================
# iStoreOS特定配置 (iStoreOS Specific Configuration)
# =============================================================================

# 如果您的路由器内存较小，可以设置Node.js内存限制
# 取消下面这行的注释并调整数值（单位：MB）
# NODE_OPTIONS="--max-old-space-size=256"

# =============================================================================
# 使用说明 (Usage Instructions)
# =============================================================================

# 1. 将此文件复制到 /etc/nodejs-argo.env
#    cp nodejs-argo.env.sample /etc/nodejs-argo.env
#
# 2. 编辑配置文件
#    vi /etc/nodejs-argo.env
#
# 3. 至少修改以下配置:
#    - UUID: 修改为您自己的UUID
#    - NAME: 设置您的节点名称
#
# 4. 根据需要配置其他选项:
#    - 如需使用固定隧道: 配置ARGO_DOMAIN和ARGO_AUTH
#    - 如需监控: 配置NEZHA_SERVER和NEZHA_KEY
#    - 如需自动上传订阅: 配置UPLOAD_URL和PROJECT_URL
#
# 5. 启动服务
#    /etc/init.d/nodejs-argo start
#
# 6. 访问订阅地址
#    http://路由器IP:3000/sub

# =============================================================================
# 安全提醒 (Security Reminder)
# =============================================================================

# 1. 请勿在公共场合分享包含您真实配置的文件
# 2. 定期更换UUID和密钥以提高安全性
# 3. 使用固定隧道时，确保ARGO_AUTH安全保存
# 4. 建议定期备份此配置文件
# 5. 仅供个人使用，禁止商业用途

# =============================================================================
# 性能优化建议 (Performance Optimization Tips)
# =============================================================================

# AX1800Pro (1GB RAM) 推荐配置:
# - NODE_OPTIONS="--max-old-space-size=256"
# - 使用固定隧道减少内存占用
# - 定期清理FILE_PATH目录
# - 关闭不必要的插件和服务
